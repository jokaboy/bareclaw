# BAREclaw configuration
BARECLAW_PORT=3000
BARECLAW_CWD=~
BARECLAW_MAX_TURNS=25
BARECLAW_ALLOWED_TOOLS=Read,Glob,Grep,Bash,Write,Edit,Skill,Task

# Per-message timeout. MUST be 0 (no timeout) in production.
# Sessions are persistent and agentic — responses can take minutes.
# A non-zero value kills the socket mid-response and corrupts channel state.
BARECLAW_TIMEOUT_MS=0

# Provider: "claude" (default). Future: "codex", "ollama"
BARECLAW_PROVIDER=claude

# Bootstrap prompt — path to a file whose contents are appended to every
# new session's system prompt. Use this to inject standing orders, vault
# context, or project-specific instructions. Sessions carry context via
# --resume so this only runs on the first message per channel.
BARECLAW_BOOTSTRAP_PROMPT=

# HTTP auth (optional — omit for unauthenticated localhost-only access)
BARECLAW_HTTP_TOKEN=

# Telegram (optional — omit to disable)
# BARECLAW_ALLOWED_USERS is required when Telegram is enabled.
BARECLAW_TELEGRAM_TOKEN=
BARECLAW_ALLOWED_USERS=
