# BAREclaw configuration
BARECLAW_PORT=3000
BARECLAW_CWD=~
BARECLAW_MAX_TURNS=25
BARECLAW_ALLOWED_TOOLS=Read,Glob,Grep,Bash,Write,Edit,Skill,Task

# Per-message timeout. MUST be 0 (no timeout) in production.
# Sessions are persistent and agentic — responses can take minutes.
# A non-zero value kills the socket mid-response and corrupts channel state.
BARECLAW_TIMEOUT_MS=0

# Stalled-turn recovery. If a busy turn produces no output for long enough,
# BAREclaw interrupts it once, then resets that channel if silence continues.
BARECLAW_STALLED_TURN_IDLE_MS=900000
BARECLAW_STALLED_TURN_INTERRUPT_GRACE_MS=30000
BARECLAW_STALLED_TURN_POLL_MS=15000

# Provider: "claude" (default). Future: "codex", "ollama"
BARECLAW_PROVIDER=codex
BARECLAW_SESSION_FILE=.bareclaw-sessions.json
BARECLAW_CHANNEL_STATE_FILE=.bareclaw-channel-state.json

# Optional obsidian-mcp bridge for canonical checkpoint/handoff sync and
# startup continuity assembly. When unset, BareClaw falls back to local-only
# continuity state.
BARECLAW_CONTINUITY_BRIDGE=
BARECLAW_CONTINUITY_PYTHON=python3

# Bootstrap prompt — path to a file whose contents are appended to every
# new session's system prompt. Use this to inject standing orders, vault
# context, or project-specific instructions. In fresh/handoff startup
# modes, BareClaw can also prepend a bounded runtime continuity block with
# project path, handoff summary, and other per-thread state.
BARECLAW_BOOTSTRAP_PROMPT=

# HTTP auth. Required for all HTTP endpoints except /healthz.
BARECLAW_HTTP_TOKEN=

# Startup warm-up (optional). Comma-separated saved channel IDs to pre-connect
# after daemon startup so existing threads are ready before the first message.
BARECLAW_WARM_CHANNELS=
BARECLAW_WARMUP_DELAY_MS=5000

# Optional explicit push target for ATTENTION responses from the heartbeat.
# When unset, install.sh falls back to the first BARECLAW_ALLOWED_USERS entry.
BARECLAW_HEARTBEAT_NOTIFY_CHANNEL=

# Telegram (optional — omit to disable)
# BARECLAW_ALLOWED_USERS is required when Telegram is enabled.
BARECLAW_TELEGRAM_TOKEN=
BARECLAW_ALLOWED_USERS=
